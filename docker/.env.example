# DB 초기 설정 (데이터베이스 초기화 시 사용)
DB_ROOT_PASSWORD=your_secure_password (DB 루트 계정 비밀번호)
DB_NAME=tallemalle (자동으로 생성될 데이터베이스 이름)

# Frontend 빌드 인자 (Vite 빌드 시 소스코드에 삽입될 값들)
# 주의: 이 값들은 frontend/.env와 동일하게 작성해야 합니다.
VITE_API_BASE_URL=http://localhost:8080 (백엔드 API 서버 주소)
VITE_WS_URL=ws://localhost:8080/ws (웹소켓 접속 주소)
